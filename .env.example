# --- Existing GCinside env ---
DATABASE_URL="postgresql://user@localhost/club_registration"
DIRECT_URL=""

OAUTH_CLIENT_ID=""
OAUTH_CLIENT_SECRET=""
OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/callback"
# Optional overrides. Defaults follow the current DataGSM OAuth docs.
# OAUTH_SCOPE=""
# OAUTH_BASE_URL="https://oauth.authorization.datagsm.kr"
# OAUTH_USERINFO_BASE_URL="https://oauth.resource.datagsm.kr"
ADMIN_EMAILS="example@gsm.hs.kr"
SESSION_SECRET="change-me-32-chars-or-more-please-please"

# --- Anti-Abuse subsystem ---
# Salt used to hash IP/device/session identifiers before persistence.
ABUSE_HASH_SALT="change-this-salt"

# Rule version label written to every RiskDecision.
ABUSE_RULE_VERSION="rules-v1"

# Master switch for hard blocks. Default false: monitor / rate-limit / challenge only.
ABUSE_ENABLE_HARD_BLOCK="false"

# fail-open lets requests through when the abuse subsystem itself errors.
ABUSE_FAIL_OPEN="true"

# Shadow mode: compute decisions but never enforce. Useful during rollout.
ABUSE_SHADOW_MODE="false"

# Canary ratio (0..1) of traffic to send through any new model variant.
ABUSE_CANARY_RATIO="0"

# Roll back to the previous model version (when supported).
ABUSE_MODEL_ROLLBACK="false"

# Default DB setting values for first boot. Admin page controls runtime values after migration.
ABUSE_AI_MODE="SHADOW"
ABUSE_ACTIVE_MODEL="mock-risk-v1"

# AI inference service (gcinside-ai-inference)
AI_INFERENCE_ENABLED="true"
AI_INFERENCE_URL="http://localhost:8081"
AI_INFERENCE_TOKEN=""
AI_INFERENCE_TIMEOUT_MS="250"
AI_INFERENCE_RETRIES="1"
